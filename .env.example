# AWS Credentials (required for S3 + DynamoDB)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# S3 bucket for storing PDFs and thumbnails
S3_BUCKET_NAME=pustak-aura-books

# DynamoDB table for book metadata (partition key: id, type: String)
DYNAMODB_TABLE_NAME=pustak-aura-books

# Optional
PORT=5000
